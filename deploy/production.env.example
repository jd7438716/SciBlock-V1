# =============================================================================
# SciBlock — Production Environment Variables Template
# =============================================================================
# 用途：复制为 /opt/sciblock/env/production.env，填写真实值后由 systemd 加载。
#
# 使用方式：
#   cp deploy/production.env.example /opt/sciblock/env/production.env
#   chmod 600 /opt/sciblock/env/production.env
#   chown sciblock:sciblock /opt/sciblock/env/production.env
#   # 然后编辑文件，替换所有 CHANGE_ME 占位符
#
# 两个 systemd service 均通过 EnvironmentFile= 加载此文件。
# sciblock-api.service 内额外设置 Environment="PORT=8080" 以覆盖 Go 的 PORT=8082。
#
# 标注说明：
#   [必填]  部署前必须替换，留空或使用示例值会导致启动失败或安全漏洞
#   [推荐]  强烈建议设置；使用默认值能运行，但不适合生产
#   [可选]  功能性可选项，不填时相关功能优雅降级
# =============================================================================


# -----------------------------------------------------------------------------
# 数据库 [必填]
# 格式: postgresql://<user>:<password>@<host>:<port>/<dbname>
# 同机部署使用 127.0.0.1（避免 localhost 可能解析到 IPv6 的 ::1）
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://sciblock:CHANGE_ME@127.0.0.1:5432/sciblock


# -----------------------------------------------------------------------------
# JWT 密钥 [必填]
# 生成命令: openssl rand -hex 32
# 警告: Go API 和 Express API 必须使用完全相同的值。
#       修改此值将使所有已登录用户的 token 立即失效。
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME


# -----------------------------------------------------------------------------
# 管理员 API 密钥 [必填]
# 用于 POST /api/admin/* 接口，创建用户、重置密码等初始化操作。
# 生成命令: openssl rand -hex 16
# -----------------------------------------------------------------------------
ADMIN_SECRET=CHANGE_ME


# =============================================================================
# Go API 配置（由 sciblock-go.service 使用）
# =============================================================================

# Go API 监听端口 [推荐保持默认]
# 若修改此值，同时需修改 sciblock-api.service 中的 GO_API_URL。
PORT=8082

# 运行环境 [必填]
# production: 强制 CORS 校验，CORS_ORIGINS 缺失时打印启动警告
# development: CORS 全放行（* ），不适用于生产
ENV=production

# 允许跨域的前端 origin [必填，ENV=production 时生效]
# 填写实际域名，包含协议和端口（标准端口 80/443 可省略端口号）。
# 多个 origin 用英文逗号分隔，不要有空格。
# 示例: https://app.example.com
# 示例（多域名）: https://app.example.com,https://www.example.com
CORS_ORIGINS=https://CHANGE_ME

# 数据库自动迁移 [必填]
# 生产环境必须设为 false，通过 pnpm migrate 手动执行迁移。
AUTO_MIGRATE=false

# bcrypt 加密强度 [推荐保持默认]
# 范围 10–14，数值越高越安全但登录越慢。12 是生产推荐值。
BCRYPT_COST=12

# JWT 有效期（小时）[推荐保持默认]
# 168 = 7 天。按安全策略调整。
JWT_EXPIRY_HOURS=168


# =============================================================================
# Express API 配置（由 sciblock-api.service 使用）
# sciblock-api.service 通过 Environment="PORT=8080" 覆盖上方的 PORT=8082
# =============================================================================

# Express 代理到 Go API 的目标地址 [必填]
# 使用 127.0.0.1 而非 localhost（避免 IPv6 解析问题）。
GO_API_URL=http://127.0.0.1:8082

# Node 运行环境 [必填]
NODE_ENV=production


# =============================================================================
# AI 集成配置 [可选]
# 不填写时前端自动显示「AI 未配置」状态，其余功能不受影响。
# GET /api/ai/status 返回 { available: false }。
# =============================================================================

# AI 提供商：qianwen | openai
# 填写后还需提供对应的 API Key。
# AI_PROVIDER=qianwen

# 阿里云百炼（通义千问）API Key
# AI_PROVIDER=qianwen 时使用
# DASHSCOPE_API_KEY=CHANGE_ME

# OpenAI API Key
# AI_PROVIDER=openai 时使用
# OPENAI_API_KEY=CHANGE_ME
