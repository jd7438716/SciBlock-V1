# =============================================================================
# SciBlock Go API Server (artifacts/go-api) — Environment Variables
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Port this Go server listens on.
# This is an internal port — not directly exposed via Replit routing.
# Express reverse-proxies selected /api/* paths here.
# Required: yes
PORT=8082

# Runtime environment.  Controls log verbosity.
# Options: development | production
# Required: no (defaults to "development")
ENV=development

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by pgx/v5.
# Same database as Express — they share one PostgreSQL instance.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Required: yes
DATABASE_URL=postgresql://postgres:password@localhost:5432/sciblock

# ---------------------------------------------------------------------------
# Authentication (JWT)
# ---------------------------------------------------------------------------

# Secret used to sign and verify JWT tokens.
# Generate a strong random value: openssl rand -hex 32
# Required: yes
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Token expiry duration in hours.
# 168 = 7 days.  Reduce to 24 for higher security environments.
# Required: no (defaults to 168)
JWT_EXPIRY_HOURS=168

# ---------------------------------------------------------------------------
# Password Hashing
# ---------------------------------------------------------------------------

# bcrypt cost factor.  Higher = slower + more secure.
# Recommended: 12 for production, 10 for development (faster tests).
# Required: no (defaults to 12)
BCRYPT_COST=12

# ---------------------------------------------------------------------------
# Object Storage — RESERVED for Phase 2 (attachment uploads)
# ---------------------------------------------------------------------------
# Uncomment when implementing file upload endpoints.

# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=sciblock-files
# STORAGE_ENDPOINT=
# STORAGE_REGION=ap-northeast-1
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
