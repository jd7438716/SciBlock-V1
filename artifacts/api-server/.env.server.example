# =============================================================================
# SciBlock Express API Server (artifacts/api-server) — Environment Variables
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Port this Express server listens on.
# Replit injects this automatically.  Set manually when self-hosting.
# Required: yes
PORT=8080

# Node environment.  Affects error verbosity and logging.
# Required: no (defaults to "development")
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Drizzle ORM.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Required: yes
DATABASE_URL=postgresql://postgres:password@localhost:5432/sciblock

# ---------------------------------------------------------------------------
# Authentication & Admin
# ---------------------------------------------------------------------------

# Secret used to guard POST /api/admin/users (create user endpoint).
# The caller must send: Authorization: Bearer <ADMIN_SECRET>
# Required: yes
ADMIN_SECRET=sciblock-admin-dev

# ---------------------------------------------------------------------------
# AI Integration
# ---------------------------------------------------------------------------

# Which AI provider to use for POST /api/ai/chat.
# Options: qianwen (default) | openai | local
# Required: no (defaults to "qianwen")
AI_PROVIDER=qianwen

# Aliyun DashScope API key.
# Required when: AI_PROVIDER=qianwen
DASHSCOPE_API_KEY=

# OpenAI API key.
# Required when: AI_PROVIDER=openai
OPENAI_API_KEY=

# Base URL for a local/self-hosted OpenAI-compatible endpoint.
# Required when: AI_PROVIDER=local
# LOCAL_AI_BASE_URL=http://localhost:11434/v1

# ---------------------------------------------------------------------------
# Go API Proxy (Phase 1 — set after Go backend is running)
# ---------------------------------------------------------------------------

# Internal URL of the Go API server.
# Express will reverse-proxy /api/scinotes, /api/experiments, /api/auth (new)
# to this address once http-proxy-middleware is wired in.
# Required: no (proxy not yet wired — Phase 1)
GO_API_URL=http://localhost:8082

# ---------------------------------------------------------------------------
# CORS (Phase 2 — tighten in production)
# ---------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins.
# Leave empty to allow all origins (current behaviour — fine for development).
# Example: https://sciblock.example.com,https://admin.sciblock.example.com
# Required: no
# CORS_ORIGINS=
