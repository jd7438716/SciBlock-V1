{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');try{fs.unlinkSync('package-lock.json')}catch(e){};try{fs.unlinkSync('yarn.lock')}catch(e){};if(!process.env.npm_config_user_agent?.includes('pnpm')){console.error('Use pnpm instead');process.exit(1)}\"",
    "dev": "sh scripts/dev.sh",
    "dev:web": "sh scripts/dev.sh web",
    "dev:api": "sh scripts/dev.sh api",
    "dev:go": "sh scripts/dev.sh go",
    "dev:go:win": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/dev-go.ps1",
    "dev:go:win:migrate": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/dev-go.ps1 -AutoMigrate",
    "build": "sh scripts/build.sh",
    "build:web": "sh scripts/build.sh web",
    "build:api": "sh scripts/build.sh api",
    "build:go": "sh scripts/build.sh go",
    "migrate": "bash scripts/migrate.sh",
    "migrate:drizzle": "bash scripts/migrate.sh drizzle",
    "migrate:goose": "bash scripts/migrate.sh goose",
    "db:generate": "pnpm --filter @workspace/db run generate",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}